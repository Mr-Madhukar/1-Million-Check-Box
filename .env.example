# ─────────────────────────────────────────────────────────────────────────────
# 2000 Checkboxes – Production Environment Variables
# Copy this to .env and fill in all values before deploying.
# NEVER commit the .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Main App ──────────────────────────────────────────────────────────────────
PORT=8080

# Public URL of the main app (Railway provides this — e.g. https://app-xxx.up.railway.app)
APP_URL=https://YOUR_RAILWAY_APP_URL_HERE

# Number of checkboxes
CHECKBOX_COUNT=2000

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave blank for no password (dev only), or set a strong password for production
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=oidc_admin
POSTGRES_PASSWORD=REPLACE_WITH_POSTGRES_PASSWORD

# ── OIDC Auth Server ──────────────────────────────────────────────────────────
# Public Railway URL for the oidc-auth service
# (Railway gives this when you deploy the oidc-auth service separately)
OIDC_ISSUER_URL=https://YOUR_RAILWAY_OIDC_URL_HERE

# Client credentials (must match what's registered in the OIDC server)
CLIENT_ID=checkboxes-app
CLIENT_SECRET=REPLACE_WITH_CLIENT_SECRET
